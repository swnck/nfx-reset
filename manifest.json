{
  "manifest_version": 3,
  "name": "NFX Reset - Clear Watch History & Continue Watching",
  "short_name": "NFX Reset",
  "version": "1.0.0",
  "description": "Reset any show or movie to Episode 1, 0:00 with a single click. Clean up your 'Continue Watching' row and fix broken autoplay.",
  "homepage_url": "https://github.com/slxca/nfx-reset",
  "permissions": [
    "cookies"
  ],
  "host_permissions": [
    "https://www.netflix.com/*",
    "https://web.prod.cloud.netflix.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.netflix.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}